{
    "schemaVersion": 1,
    "id": "${modId}",
    "version": "${modVersion}",
    "name": "${modName}",
    "icon": "${modId}.png",
    "environment": "*",
    "entrypoints": {
        "main": [
            "com.denisjava.extended_interactions.fabric.EIFabric"
        ],
        "client": [
            "com.denisjava.extended_interactions.fabric.EIClientFabric"
        ],
        "extended_interactions": [
            "com.denisjava.extended_interactions.debug.DebugPlugin",
            "com.denisjava.extended_interactions.config.EIDataManager"
        ],
        "modmenu": [
            "com.denisjava.extended_interactions.fabric.ModMenuCompat"
        ]
    },
    "contact": {
        "homepage": "${modURL}"
    },
    "mixins": [
        "extended_interactions.mixins.json",
        "extended_interactions.fabric.mixins.json"
    ],
    "depends": {
        "fabricloader": "${fabricLoaderVersionRange}",
        "minecraft": "${minecraftVersion}",
        "java": ">=${javaVersion}",
        "fabric-api": "${fabricAPIVersionRange}",
        "yet_another_config_lib_v3": "*"
    }
}